# --- Required connection settings / Zorunlu bağlantı ayarları ---
MSSQL_HOST=YOUR_SERVER_HOST_OR_IP
MSSQL_PORT=1433
MSSQL_USER=YOUR_READONLY_USER
MSSQL_PASSWORD=YOUR_PASSWORD
MSSQL_DATABASE=YOUR_DATABASE

# --- TLS ---
# Encrypt the connection (default: true)
MSSQL_ENCRYPT=true
# Accept self-signed certificates (default: false). Only enable on trusted networks.
MSSQL_TRUST_CERT=false

# --- Optional security settings (defaults are the safe side) ---
# Per-query timeout in milliseconds (default: 30000)
QUERY_TIMEOUT_MS=30000
# Result sets are truncated at this many rows (default: 1000)
MAX_ROWS=1000
# Optional comma-separated table allowlist. Empty = all tables.
# Example: ALLOWED_TABLES=dbo.Customers,dbo.Orders,Sales.Invoices
ALLOWED_TABLES=
# Optional JSON-lines audit log file. Credentials are never logged.
LOG_FILE=
